# WINGS PMS 설정
WINGS_URL=https://wings.kolon.com/pms/biz/fd01_2400_V50/searchListRoomIndicator.do
WINGS_LOGIN_URL=https://wings.kolon.com/pms
WINGS_COMPANY_ID=          # 3번째 로그인 항목 (회사코드)
WINGS_ID=                  # WINGS 로그인 ID
WINGS_PW=                  # WINGS 로그인 PW
PROPERTY_NO=11
BSNS_CODE=11

# Supabase 설정
SUPABASE_URL=              # https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=      # service_role key (Settings → API)

# 스크래핑 간격 (초, 기본 300 = 5분)
SCRAPE_INTERVAL=300

# 운영 시간 설정 (24시간제, 이 범위 밖이면 대기)
# 예: 오전 6시 ~ 오후 11시 운영 → 23시~6시는 수집 안 함
SCRAPE_HOUR_START=6
SCRAPE_HOUR_END=23
